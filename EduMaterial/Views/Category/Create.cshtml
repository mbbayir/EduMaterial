
@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_LayoutPanel.cshtml";
}

@model IEnumerable<Category>

<table class="table">
    <thead>
        <tr>
            <th>Kategori Adı</th>
            <th>İşlemler</th>

        </tr>
    </thead>
    <tbody>
    <tbody>
            @foreach (var category in Model)
            {
            <tr>
                <td>@category.Name</td>
                <td>
                    <button class="btn btn-primary editBtn" data-id="@category.Id">Düzenle</button>
                    <button class="btn btn-danger deleteBtn" data-id="@category.Id">Sil</button>
                </td>
            </tr>
            }
    </tbody>
</table>


<div id="myModal" class="modal-fade" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Kategori Düzenle</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">

                <form id=editForm>
                    <input type="hidden" id="editCategoryId"/>
                    <div class="form-group">
                        <label for="editCategoryName">Kategori Adı:</label>
                        <input type="text" class="form-control" id="editCategoryName">
                    </div>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts
{<script>
    $(document).ready(function () {

    })

</script>

}
