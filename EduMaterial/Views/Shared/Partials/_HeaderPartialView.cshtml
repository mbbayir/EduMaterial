<header class="header">
	<div class="logo-container">
		<a href="../4.0.0" class="logo">
			<img src="/Panel/img/logo.png" width="75" height="35" alt="Porto Admin" />
		</a>

		<div class="d-md-none toggle-sidebar-left" data-toggle-class="sidebar-left-opened" data-target="html" data-fire-event="sidebar-left-opened">
			<i class="fas fa-bars" aria-label="Toggle sidebar"></i>
		</div>

	</div>

	<!-- start: search & user box -->
	<div class="header-right">



		<span class="separator"></span>
		<div id="userbox" class="userbox">
			<button class="btn btn-link" type="button" id="userOptionsDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
				Merhaba @User.Identity.Name,
				<i class="fa custom-caret"></i>
			</button>


			<div class="dropdown-menu" aria-labelledby="userOptionsDropdown">
				<div class="dropdown-divider"></div>
				<form asp-area="" asp-controller="Home" asp-action="Logout" method="post" onsubmit="changeButtonColor(this)">
					<button type="submit" class="dropdown-item" id="logoutButton">Logout</button>
				</form>
			</div>
		</div>
	</div>
	<!-- end: search & user box -->
</header>